<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Ficha de Personagem - {{nome}}</title>
    <style>
        :root {
            --bg-color: #0d1117;
            --card-bg: #161b22;
            --border-color: #30363d;
            --text-main: #c9d1d9;
            --text-dim: #8b949e;
            --accent: #238636; /* Verde RPG */
            --accent-dark: #2ea043;
        }

        @page {
            size: A4 landscape;
            margin: 0;
        }

        body {
            margin: 0;
            padding: 20px;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            width: 297mm;
            height: 210mm;
            box-sizing: border-box;
        }

        .sheet-container {
            display: grid;
            grid-template-columns: 350px 1fr 1fr;
            grid-template-rows: auto 1fr;
            gap: 20px;
            height: 100%;
        }

        /* Hero Section */
        .hero-panel {
            grid-row: 1 / 3;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .avatar-container {
            width: 100%;
            height: 400px;
            border-radius: 8px;
            overflow: hidden;
            border: 2px solid var(--accent);
        }

        .avatar-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .character-name {
            font-size: 28px;
            font-weight: 800;
            margin: 0;
            color: white;
            text-align: center;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 5px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .stat-box {
            background: rgba(255, 255, 255, 0.05);
            padding: 10px;
            border-radius: 6px;
            text-align: center;
        }

        .stat-label {
            font-size: 10px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-value {
            font-size: 20px;
            font-weight: bold;
            color: var(--accent-dark);
        }

        /* Bio */
        .header-panel {
            grid-column: 2 / 4;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .bio-item {
            display: flex;
            flex-direction: column;
        }

        .bio-label { font-size: 12px; color: var(--text-dim); }
        .bio-value { font-size: 18px; font-weight: 600; }

        /* Main Content */
        .main-panel {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            overflow-y: hidden;
        }

        h2 {
            font-size: 18px;
            margin-top: 0;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
        }

        h2::after {
            content: "";
            flex: 1;
            height: 1px;
            background: var(--border-color);
        }

        .list-items {
            list-style: none;
            padding: 0;
            margin: 0;
            font-size: 13px;
        }

        .list-items li {
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            display: flex;
            justify-content: space-between;
        }

        .description-text {
            font-size: 13px;
            line-height: 1.6;
            color: var(--text-dim);
        }

        .hp-bar {
            height: 8px;
            background: #222;
            border-radius: 4px;
            overflow: hidden;
            margin-top: 5px;
        }
        .hp-fill {
            height: 100%;
            background: var(--accent);
            width: 100%;
        }

    </style>
</head>
<body>
    <div class="sheet-container">
        <!-- Panel 1: Hero -->
        <div class="hero-panel">
            <div class="avatar-container">
                <img src="{{imageDataUri}}" alt="Personagem">
            </div>
            <h1 class="character-name">{{nome}}</h1>
            
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-label">Força</div>
                    <div class="stat-value">{{atributos.forca}} ({{modifier atributos.forca}})</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Destreza</div>
                    <div class="stat-value">{{atributos.destreza}} ({{modifier atributos.destreza}})</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Constituição</div>
                    <div class="stat-value">{{atributos.constituicao}} ({{modifier atributos.constituicao}})</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Inteligência</div>
                    <div class="stat-value">{{atributos.inteligencia}} ({{modifier atributos.inteligencia}})</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Sabedoria</div>
                    <div class="stat-value">{{atributos.sabedoria}} ({{modifier atributos.sabedoria}})</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Carisma</div>
                    <div class="stat-value">{{atributos.carisma}} ({{modifier atributos.carisma}})</div>
                </div>
            </div>

            <div style="margin-top: 10px;">
                <div class="bio-label">Pontos de Vida</div>
                <div class="bio-value">{{pontos_de_vida}}</div>
                <div class="hp-bar"><div class="hp-fill"></div></div>
            </div>
        </div>

        <!-- Panel 2: Header Info -->
        <div class="header-panel">
            <div class="bio-item">
                <span class="bio-label">Raça</span>
                <span class="bio-value">{{raca}}</span>
            </div>
            <div class="bio-item">
                <span class="bio-label">Classe / Nível</span>
                <span class="bio-value">{{classe}} (Nível {{nivel}})</span>
            </div>
            <div class="bio-item">
                <span class="bio-label">Antecedente</span>
                <span class="bio-value">{{antecedente}}</span>
            </div>
            <div class="bio-item">
                <span class="bio-label">Alinhamento</span>
                <span class="bio-value">{{alinhamento}}</span>
            </div>
        </div>

        <!-- Panel 3: Skills & Equipment -->
        <div class="main-panel">
            <h2>Perícias e Habilidades</h2>
            <ul class="list-items">
                {{#each pericias}}
                    <li>{{this}}</li>
                {{/each}}
                {{#each habilidades}}
                    <li>{{this}}</li>
                {{/each}}
            </ul>

            <h2 style="margin-top:20px">Equipamento</h2>
            <ul class="list-items">
                {{#each equipamentos}}
                    <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>

        <!-- Panel 4: Story & Appearance -->
        <div class="main-panel">
            <h2>Personalidade e História</h2>
            <div class="description-text">
                <p><strong>Personalidade:</strong> {{personalidade}}</p>
                <p><strong>História:</strong> {{historia}}</p>
            </div>

            <h2 style="margin-top:20px">Magias Conhecidas</h2>
            <ul class="list-items">
                {{#each magias}}
                    <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>
    </div>
</body>
</html>
